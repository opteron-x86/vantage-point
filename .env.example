# =============================================================================
# Market Assistant configuration
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Database ---
# For local Docker Postgres (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_assistant

# --- Market data (Alpaca free paper trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- News (Finnhub free tier) ---
FINNHUB_API_KEY=

# --- AI provider: "anthropic" or "openrouter" ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional model overrides (leave blank to use defaults)
# MODEL_BRIEFING=
# MODEL_CLASSIFIER=

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-48-byte-urlsafe-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# --- Backend server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Frontend (optional; the frontend reads NEXT_PUBLIC_API_URL from frontend/.env.local) ---
