# ---- Environment ----
# Set to "production" on Railway. This enables safety checks that will refuse
# to start the app if required vars are missing or still at default values.
ENVIRONMENT=production

# ---- Database ----
# Railway's Postgres addon exposes this automatically as a reference:
#   ${{Postgres.DATABASE_URL}}
# Leave blank when deploying — bind it in Railway's UI to the Postgres service.
DATABASE_URL=

# ---- Auth ----
# REQUIRED. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Must be 32+ characters. The prod safety check will reject the default.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ---- Bootstrap (first-user setup) ----
# Set this to enable the one-time /setup page in the web UI. Use the same
# random-string generator as JWT_SECRET. After you create your account,
# unset this variable — the setup page will refuse to work once a user exists,
# but removing the token closes the door entirely.
BOOTSTRAP_TOKEN=

# ---- CORS ----
# Comma-separated list of frontend origins allowed to hit this API.
# Set to your Railway frontend's public domain (with https://).
# Example: CORS_ORIGINS=https://market-assistant-frontend-production.up.railway.app
CORS_ORIGINS=

# ---- AI provider ----
# Either "anthropic" or "openrouter" — set the matching key below.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional — override model selection. Defaults live in app/ai/client.py.
# MODEL_BRIEFING=claude-sonnet-4-5
# MODEL_CLASSIFIER=claude-haiku-4-5-20251001

# ---- Market data ----
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ---- News ----
FINNHUB_API_KEY=

# ---- Server ----
# Railway injects PORT at runtime. Don't override unless you know why.
# PORT is read by entrypoint.sh.
