# ---- API endpoints ----
# These are baked into the client bundle AT BUILD TIME, not read at runtime.
# On Railway, set them as "Build Variables" (not just env vars), OR use
# Railway's reference syntax in the service's build args:
#
#   NEXT_PUBLIC_API_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}
#   NEXT_PUBLIC_WS_URL=wss://${{backend.RAILWAY_PUBLIC_DOMAIN}}
#
# Note the protocols: https for the REST URL, wss (WebSocket Secure) for the WS URL.
# Do NOT use http:// or ws:// in production — browsers will block mixed content.

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
